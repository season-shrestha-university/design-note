{
  "name": "nuclear-neutron",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build:index": "node scripts/build-search-index.js",
    "build": "pnpm run build:index && astro build && pagefind --site dist && pagefind --site .vercel/output/static",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.0",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/vercel": "^10.0.8",
    "@google/genai": "^2.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.4.7",
    "astro-icon": "^1.1.5",
    "pagefind": "^1.5.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "protobufjs"
    ]
  }
