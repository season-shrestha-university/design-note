{
  "name": "nuclear-neutron",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build:index": "node scripts/build-search-index.js",
    "build": "pnpm run build:index && astro build && pagefind --site dist && pagefind --site .vercel/output/static",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "a11y": "astro build && node scripts/a11y-check.mjs",
    "a11y:check": "node scripts/a11y-check.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.4",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^11.0.3",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-sans-condensed": "^5.2.8",
    "@google/genai": "^2.8.0",
    "@microsoft/clarity": "^1.0.2",
    "@supabase/supabase-js": "^2.108.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^7.0.9",
    "astro-icon": "^1.1.5",
    "fuse.js": "^7.4.2",
    "pagefind": "^1.5.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "protobufjs"
    ],
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  }
}
