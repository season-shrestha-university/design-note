---
import { getCollection } from "astro:content";

import Header from "@/components/Header.astro";
import { dateFormatter, formatCategoryLabel } from "@/utils";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const categories = [
    ...new Set(articles.map((article) => article.id.split("/")[0])),
  ];

  return categories.map((category) => ({
    params: { category },
  }));
}

const category = Astro.params.category as string;

const categoryArticles = (
  await getCollection("articles", ({ id }) => id.split("/")[0] === category)
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<Layout title={`${formatCategoryLabel(category)} / Design Note`}>
  <Header activeSection={category} />
  <main>
    <header>
      <h1>{formatCategoryLabel(category)}</h1>
      <p>Collection managed with MDX content files.</p>
    </header>
    <div>
      {
        categoryArticles.map((article, index) => (
          <article style={`animation-delay: ${(index + 1) * 0.1}s`}>
            <div>
              <span>{dateFormatter.format(article.data.publishedAt)}</span>
              <span>Read: {article.data.readTime}</span>
            </div>
            <a href={`/articles/${article.id}/`}>
              <div>
                <div>{String(index + 1).padStart(2, "0")}</div>
                <h3>{article.data.title}</h3>
                <p>{article.data.excerpt}</p>
                <div>Read Entry</div>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </main>
</Layout>
