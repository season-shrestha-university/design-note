---
import { getCollection } from "astro:content";

import {
  CATEGORY_ICONS,
  breadcrumbSchema,
  fadeUp,
  formatCategoryLabel,
} from "@/utils";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  const categories = [
    ...new Set(articles.map((article) => article.id.split("/")[0])),
  ];

  return categories.map((category) => ({
    params: { category },
  }));
}

const category = Astro.params.category as string;

const categoryArticles = (
  await getCollection("articles", ({ id }) => id.split("/")[0] === category)
).sort((a, b) => {
  const aTime = a.data.publishedAt?.getTime() ?? 0;
  const bTime = b.data.publishedAt?.getTime() ?? 0;
  return bTime - aTime;
});

const categoryLabel = formatCategoryLabel(category);
const description = `Design notes on ${categoryLabel.toLowerCase()} — ${categoryArticles.length} browsable references on interface patterns and why they work.`;

const structuredData = [
  breadcrumbSchema({
    items: [
      { name: "Home", url: new URL("/", Astro.site).toString() },
      {
        name: "Categories",
        url: new URL("/categories/", Astro.site).toString(),
      },
      {
        name: categoryLabel,
        url: new URL(`/categories/${category}/`, Astro.site).toString(),
      },
    ],
  }),
];
---

<Layout title={categoryLabel} description={description} jsonLd={structuredData}>
  <main transition:animate={fadeUp}>
    <header class="category-title">
      <img src={CATEGORY_ICONS[category]} alt={formatCategoryLabel(category)} />
      <h1>
        {formatCategoryLabel(category)}
      </h1>
    </header>
    <div>
      {
        categoryArticles.map((article, index) => (
          <article>
            <a href={`/articles/${article.id}/`} class="card">
              <div class="card__body">
                <span class="card__index">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <h2 class="card__title">{article.data.title}</h2>
                <p class="card__excerpt">{article.data.excerpt}</p>
                <span class="card__badge">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="17"
                    height="17"
                    fill="none"
                    viewBox="0 0 17 17"
                    aria-hidden="true"
                  >
                    <circle
                      cx="8.5"
                      cy="8.5"
                      r="6.25"
                      stroke="currentColor"
                      stroke-width="1.5"
                    />
                    <path
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M8.5 5.25V8.5l2.125 1.062"
                    />
                  </svg>
                  {article.data.readTime} read
                </span>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </main>
</Layout>

<style>
  .category-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-2xl);
    color: var(--primary-color);
  }
</style>
