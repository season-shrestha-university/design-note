---
import { getCollection } from 'astro:content';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
import '../../styles/main.css';
import { dateFormatter, formatCategoryLabel } from '../../utils';

export async function getStaticPaths() {
	const articles = await getCollection('articles');
	const categories = [...new Set(articles.map((article) => article.id.split('/')[0]))];

	return categories.map((category) => ({
		params: { category }
	}));
}

const category = Astro.params.category as string;

const categoryArticles = (await getCollection('articles', ({ id }) => id.split('/')[0] === category)).sort(
	(a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime()
);

---

<Layout title={`${formatCategoryLabel(category)} / Design Note`}>
	<Header activeSection={category} />
	<main class="content-area">
		<header class="feed-header">
			<h1 class="feed-title caps">{formatCategoryLabel(category)}</h1>
			<p class="feed-subtitle">Collection managed with MDX content files.</p>
			<p class="sub-category-label caps">Articles in this category</p>
		</header>
		<div class="articles-grid">
			{
				categoryArticles.map((article, index) => (
					<article class="article-block" style={`animation-delay: ${(index + 1) * 0.1}s`}>
						<div class="article-meta">
							<span class="meta-pill">{dateFormatter.format(article.data.publishedAt)}</span>
							<span class="meta-pill">Read: {article.data.readTime}</span>
						</div>
						<div class="article-main">
							<a class="article-link" href={`/articles/${article.id}/`}>
								<div class="article-content-pill">
									<div class="article-large-num t-mono-num">{String(index + 1).padStart(2, '0')}</div>
									<h3 class="article-title">{article.data.title}</h3>
									<p class="article-excerpt">{article.data.excerpt}</p>
									<div class="read-more">Read Entry</div>
								</div>
							</a>
						</div>
					</article>
				))
			}
		</div>
	</main>
	<Footer />
</Layout>
