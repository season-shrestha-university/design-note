---
import { getCollection, getEntry, render } from "astro:content";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Layout from "../../layouts/Layout.astro";
import { deriveCategory } from "../../utils";
const fadeUp = {
  forwards: {
    old: {
      name: "fadeUpOut",
      duration: "0.45s",
      easing: "ease-in",
      fillMode: "forwards",
    },
    new: {
      name: "fadeUpIn",
      duration: "0.55s",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "backwards",
    },
  },
  backwards: {
    old: {
      name: "fadeUpOut",
      duration: "0.45s",
      easing: "ease-in",
      fillMode: "forwards",
    },
    new: {
      name: "fadeUpIn",
      duration: "0.55s",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "backwards",
    },
  },
};

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const slug = Astro.params.slug;
const article = slug ? await getEntry("articles", slug) : undefined;

if (!article) {
  throw new Response("Article not found", { status: 404 });
}

const { Content } = await render(article);
const articleCategory = deriveCategory(article.id);
---

<Layout title={`title / Design Note`}>
  <div transition:animate={fadeUp}>
    <Header activeSection={articleCategory} />
    <main>
      <header class="note__header">
        <h1 class="note__title">The Ripple / Impact Shape</h1>
        <span class="note_category card__badge">Interaction</span>
        <p class="note__subtitle">
          The tendency for people to get overwhelmed when they are presented
          with a large number of options, often used interchangeably with the
          term paradox of choice.
        </p>
        <img class="note__visual" src="/interaction-fade.svg" alt="" />
      </header>
      <ol class="note__takeaway">
        <li class="note__takeaway__item">
          <span class="note__takeaway__number">01</span>
          <p>
            The core of the interface is defined by a monolithic, dark-chrome
            pillar rising seamlessly from a matte, charcoal-grey canvas. It is
            static, commanding, and perfectly still—until the moment of contact.
          </p>
        </li>
        <li class="note__takeaway__item">
          <span class="note__takeaway__number">02</span>
          <p>
            The core of the interface is defined by a monolithic, dark-chrome
            pillar rising seamlessly from a matte, charcoal-grey canvas. It is
            static, commanding, and perfectly still—until the moment of contact.
          </p>
        </li>
        <li class="note__takeaway__item">
          <span class="note__takeaway__number">03</span>
          <p>
            The core of the interface is defined by a monolithic, dark-chrome
            pillar rising seamlessly from a matte, charcoal-grey canvas. It is
            static, commanding, and perfectly still—until the moment of contact.
          </p>
        </li>
      </ol>
      <p class="note__description">
        The core of the interface is defined by a monolithic, dark-chrome pillar
        rising seamlessly from a matte, charcoal-grey canvas. It is static,
        commanding, and perfectly still—until the moment of contact.
      </p>
    </main>
  </div>
  <Footer />
</Layout>
