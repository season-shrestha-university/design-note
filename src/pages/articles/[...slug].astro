---
import { getCollection, getEntry, render } from "astro:content";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Layout from "../../layouts/Layout.astro";
import "../../styles/main.css";
import { deriveCategory, formatCategoryLabel } from "../../utils";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const slug = Astro.params.slug;
const article = slug ? await getEntry("articles", slug) : undefined;

if (!article) {
  throw new Response("Article not found", { status: 404 });
}

const { Content } = await render(article);
const articleCategory = deriveCategory(article.id);
const { dateFormatter } = await import("../../utils");
---

<Layout title={`${article.data.title} / Design Note`}>
  <Header activeSection={articleCategory} />
  <main class="content">
    <header class="feed-header">
      <h1 class="feed-header__title">{article.data.title}</h1>
      <div class="feed-header__meta">
        <span class="feed-header__meta-pill"
          >{dateFormatter.format(article.data.publishedAt)}</span
        >
        <span class="feed-header__meta-pill">Read: {article.data.readTime}</span
        >
        <span class="feed-header__meta-pill"
          >{formatCategoryLabel(articleCategory)}</span
        >
      </div>
    </header>
    <article class="article-detail article-body">
      <Content />
    </article>
  </main>
  <Footer />
</Layout>
