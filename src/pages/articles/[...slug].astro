---
import { getCollection, getEntry, render } from "astro:content";

import {
  CATEGORY_ICONS,
  absoluteUrl,
  articleSchema,
  breadcrumbSchema,
  deriveCategory,
  fadeUp,
  formatCategoryLabel,
} from "@/utils";
import Figure from "@components/ui/Figure.astro";
import FurtherReadingCard from "@components/ui/FurtherReadingCard.astro";
import Layout from "@layouts/Layout.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.id },
  }));
}

const slug = Astro.params.slug;
const article = slug ? await getEntry("articles", slug) : undefined;

if (!article) {
  throw new Response("Article not found", { status: 404 });
}

const articleCategory = deriveCategory(article.id);
const categoryIcon =
  CATEGORY_ICONS[articleCategory] ?? "/icons/categories/fundamental-icon.svg";
const takeaways = article.data.takeaways;
const furtherReading = article.data.furtherReading;
const { Content } = await render(article);

const categoryLabel = formatCategoryLabel(articleCategory);
const canonicalURL = new URL(`/articles/${article.id}/`, Astro.site).toString();
const shareImage = absoluteUrl(article.data.ogImage, Astro.site);

const structuredData = [
  articleSchema({
    title: article.data.title,
    description: article.data.excerpt,
    url: canonicalURL,
    image: shareImage,
    publishedTime: article.data.publishedAt,
    modifiedTime: article.data.updatedAt,
    author: article.data.author,
    section: categoryLabel,
  }),
  breadcrumbSchema({
    items: [
      { name: "Home", url: new URL("/", Astro.site).toString() },
      {
        name: categoryLabel,
        url: new URL(`/categories/${articleCategory}/`, Astro.site).toString(),
      },
      { name: article.data.title, url: canonicalURL },
    ],
  }),
];
---

<Layout
  title={article.data.title}
  description={article.data.excerpt}
  type="article"
  image={article.data.ogImage}
  section={categoryLabel}
  publishedTime={article.data.publishedAt}
  modifiedTime={article.data.updatedAt}
  jsonLd={structuredData}
>
  <div transition:animate={fadeUp}>
    <main>
      <header class="note__header">
        <h1 class="note__title">{article.data.title}</h1>
        <span class="note_category card__badge"
          >{formatCategoryLabel(articleCategory)}</span
        >
        <p class="note__subtitle">
          {article.data.excerpt}
        </p>
        <img class="note__visual" src={categoryIcon} alt="" />
      </header>
      <ol class="note__takeaway">
        {
          takeaways?.map((takeaway, index) => (
            <li class="note__takeaway__item">
              <span class="note__takeaway__number">
                {String(index + 1).padStart(2, "0")}
              </span>
              <p>{takeaway}</p>
            </li>
          ))
        }
      </ol>
      <div class="note__description">
        <Content components={{ Figure }} />
      </div>

      {
        furtherReading && furtherReading.length > 0 && (
          <>
            <h2 class="note__further__reading__title">Further Reading</h2>
            <ul class="note__further__reading__list">
              {furtherReading.map((item) => (
                <FurtherReadingCard
                  title={item.title}
                  subtitle={item.subtitle}
                  href={item.link}
                />
              ))}
            </ul>
          </>
        )
      }
    </main>
  </div>
</Layout>
