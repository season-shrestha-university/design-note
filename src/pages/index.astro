---
import { getCollection } from "astro:content";

import Header from "@/components/Header.astro";
import Footer from "@components/common/Footer.astro";
import Card from "@components/ui/Card.astro";
import Layout from "@layouts/Layout.astro";
import { deriveCategory } from "@/utils";

const fadeUp = {
  forwards: {
    old: {
      name: "fadeUpOut",
      duration: "0.2s",
      easing: "ease-in",
      fillMode: "forwards",
    },
    new: {
      name: "fadeUpIn",
      duration: "0.3s",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "backwards",
    },
  },
  backwards: {
    old: {
      name: "fadeUpOut",
      duration: "0.2s",
      easing: "ease-in",
      fillMode: "forwards",
    },
    new: {
      name: "fadeUpIn",
      duration: "0.3s",
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fillMode: "backwards",
    },
  },
};

const isHomePage = Astro.url.pathname === "/";

const articles = (await getCollection("articles")).sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return Number(b.data.featured) - Number(a.data.featured);
  }
  return b.data.publishedAt.getTime() - a.data.publishedAt.getTime();
});
---

<Layout class="container">
  <div transition:animate={fadeUp}>
    {!isHomePage && <Header activeSection="home" />}
    <main>
      <header class="page-header">
        <div
          style="display: flex; justify-content: space-between; align-items: flex-start; gap: var(--spacing-md);"
        >
          <div>
            <h1 class="page-title">Design Note</h1>
            <p class="page-subtitle">
              A UI design reference system that explains everyday interface
              patterns and why they work through typography, grids, visual
              hierarchy, interactions, and core design principles.
            </p>
          </div>
        </div>
      </header>
      <section>
        {
          articles.map((article, index) => (
            <Card
              title={article.data.title}
              excerpt={article.data.excerpt}
              readTime={article.data.readTime}
              category={deriveCategory(article.id)}
              index={index + 1}
              href={`/articles/${article.id}/`}
            />
          ))
        }
      </section>
    </main>
    <Footer />
  </div>
</Layout>
