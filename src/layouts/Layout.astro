---
import Header from "@/components/common/Header.astro";
import QuickAccess from "@components/common/QuickAccess.astro";
import Clarity from "@components/common/Clarity.astro";
import SEO from "@components/common/SEO.astro";
import { SITE, websiteSchema, type JsonLd, type SeoProps } from "@/utils";
import "@fontsource/ibm-plex-sans/latin-400.css";
import "@fontsource/ibm-plex-sans/latin-400-italic.css";
import "@fontsource/ibm-plex-sans/latin-500.css";
import "@fontsource/ibm-plex-sans/latin-600.css";
import "@fontsource/ibm-plex-sans/latin-700.css";
import "@fontsource/ibm-plex-sans-condensed/latin-700.css";
import "@fontsource/ibm-plex-mono/latin-700.css";
import "@styles/main.css";
import SpeedInsights from "@vercel/speed-insights/astro";
import { ClientRouter } from "astro:transitions";

interface Props extends SeoProps {
  class?: string;
}

const { class: className, jsonLd, ...seo } = Astro.props;

// Every page carries the WebSite schema; pages may append their own (Article, Breadcrumb).
const structuredData: JsonLd[] = [
  websiteSchema({ site: Astro.site }),
  ...(jsonLd ?? []),
];
---

<!doctype html>
<html lang={SITE.lang} transition:name="root" transition:animate="none">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SEO {...seo} jsonLd={structuredData} />
    <Clarity />
  </head>
  <body class:list={["container", className]}>
    <slot />
    <Header hidden={Astro.url.pathname === "/"} />
    <QuickAccess />
    <SpeedInsights />
  </body>
</html>
