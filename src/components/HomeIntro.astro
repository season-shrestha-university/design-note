---
import { getCollection } from 'astro:content';
import { deriveCategory, formatCategoryLabel } from '../utils';

const articles = await getCollection('articles');
const categoryMap = new Map<string, number>();

for (const article of articles) {
	const category = deriveCategory(article.id);
	categoryMap.set(category, (categoryMap.get(category) ?? 0) + 1);
}

const categoryCards = [...categoryMap.entries()]
	.map(([category, count]) => ({
		title: formatCategoryLabel(category),
		description: `${count} article${count === 1 ? '' : 's'} in this collection.`,
		href: `/categories/${category}/`
	}))
	.sort((a, b) => a.title.localeCompare(b.title));
---

<main class="content-area">
	<header class="feed-header">
		<h1 class="feed-title caps">Design Note</h1>
		<p class="feed-subtitle">
			A learning log and reference library across typography, grid systems, visual theory, and
			design history.
		</p>
	</header>

	<section class="home-links-grid">
		{
			categoryCards.map((card) => (
				<a class="article-content-pill home-link-card" href={card.href}>
					<h2 class="article-title">{card.title}</h2>
					<p class="article-excerpt">{card.description}</p>
					<div class="read-more">Open Category</div>
				</a>
			))
		}
	</section>
</main>
