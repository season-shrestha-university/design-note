---
import { getCollection } from "astro:content";
import { deriveCategory, formatCategoryLabel } from "../utils";

const articles = await getCollection("articles");
const categoryMap = new Map<string, number>();
for (const article of articles) {
  const category = deriveCategory(article.id);
  categoryMap.set(category, (categoryMap.get(category) ?? 0) + 1);
}

const categoryCards = [...categoryMap.entries()]
  .map(([category, count]) => ({
    title: formatCategoryLabel(category),
    description: `${count} Note${count === 1 ? "" : "s"}`,
    href: `/categories/${category}/`,
  }))
  .sort((a, b) => a.title.localeCompare(b.title));
---

<main>
  <header class="page-header">
    <h1 class="page-title">Design Note</h1>
    <p class="page-subtitle">
      A UI design reference system that explains everyday interface patterns and
      why they work through typography, grids, visual hierarchy, interactions,
      and core design principles.
    </p>
  </header>

  <section>
    <!-- {
      categoryCards.map((card, index) => (
        <article>
          <a href={card.href}>
            <div>
              <div>{String(index + 1).padStart(2, "0")}</div>
              <h2>{card.title}</h2>
              <p>{card.description}</p>
              <div>Open Category</div>
            </div>
          </a>
        </article>
      ))
    } -->

    <div class="tab">
      <input
        class="tab__radio tab__radio--1"
        type="radio"
        name="tab"
        id="tab-1"
        checked
      />
      <input
        class="tab__radio tab__radio--2"
        type="radio"
        name="tab"
        id="tab-2"
      />

      <nav class="tab__nav">
        <label class="tab__button tab__button--1" for="tab-1">
          <img
            src="/icons/latest-article-icon.svg"
            alt=""
            height="32"
            width="32"
          /> Latest Notes</label
        >
        <label class="tab__button tab__button--2" for="tab-2">
          <img
            src="/public/icons/category-icon.svg"
            alt=""
            height="32"
            width="32"
          /> View Category</label
        >
      </nav>

      <div class="tab__panels">
        <div class="tab__panel tab__panel--1">
          <p>Categories content goes here.</p>
        </div>
        <div class="tab__panel tab__panel--2">
          <p>Recent content goes here.</p>
        </div>
      </div>
    </div>
  </section>
</main>
