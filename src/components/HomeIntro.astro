---
import { getCollection } from "astro:content";
import { deriveCategory, formatCategoryLabel } from "../utils";
import Card from "./Card.astro";

const articles = await getCollection("articles");
const categoryMap = new Map<string, number>();
for (const article of articles) {
  const category = deriveCategory(article.id);
  categoryMap.set(category, (categoryMap.get(category) ?? 0) + 1);
}

const categoryCards = [...categoryMap.entries()]
  .map(([category, count]) => ({
    title: formatCategoryLabel(category),
    description: `${count} Note${count === 1 ? "" : "s"}`,
    href: `/categories/${category}/`,
  }))
  .sort((a, b) => a.title.localeCompare(b.title));
---

<main>
  <header class="page-header">
    <h1 class="page-title">Design Note</h1>
    <p class="page-subtitle">
      A UI design reference system that explains everyday interface patterns and
      why they work through typography, grids, visual hierarchy, interactions,
      and core design principles.
    </p>
  </header>

  <section>
    <!-- {
      categoryCards.map((card, index) => (
        <article>
          <a href={card.href}>
            <div>
              <div>{String(index + 1).padStart(2, "0")}</div>
              <h2>{card.title}</h2>
              <p>{card.description}</p>
              <div>Open Category</div>
            </div>
          </a>
        </article>
      ))
    } -->

    <div class="tab">
      <input
        class="tab__radio tab__radio--1"
        type="radio"
        name="tab"
        id="tab-1"
        checked
      />
      <input
        class="tab__radio tab__radio--2"
        type="radio"
        name="tab"
        id="tab-2"
      />

      <nav class="tab__nav">
        <label class="tab__button tab__button--1" for="tab-1">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="none"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="M23.547 14.933c-.307-.4-.68-.746-1.027-1.093-.893-.8-1.907-1.373-2.76-2.213C17.773 9.68 17.333 6.467 18.6 4c-1.267.307-2.373 1-3.32 1.76-3.453 2.773-4.813 7.667-3.187 11.867.054.133.107.266.107.44 0 .293-.2.56-.467.666-.306.134-.626.054-.88-.16a.8.8 0 0 1-.186-.226c-1.507-1.907-1.747-4.64-.734-6.827-2.226 1.813-3.44 4.88-3.266 7.773.08.667.16 1.334.386 2 .187.8.547 1.6.947 2.307 1.44 2.307 3.933 3.96 6.613 4.293 2.854.36 5.907-.16 8.094-2.133 2.44-2.213 3.293-5.76 2.04-8.8l-.174-.347c-.28-.613-1.026-1.68-1.026-1.68m-4.214 8.4c-.373.32-.986.667-1.466.8-1.494.534-2.987-.213-3.867-1.093 1.587-.373 2.533-1.547 2.813-2.733.227-1.067-.2-1.947-.373-2.974-.16-.986-.133-1.826.227-2.746.253.506.52 1.013.84 1.413 1.026 1.333 2.64 1.92 2.986 3.733.054.187.08.374.08.574.04 1.093-.44 2.293-1.24 3.026"
            ></path></svg
          > Latest Notes</label
        >
        <label class="tab__button tab__button--2" for="tab-2">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="none"
            viewBox="0 0 32 32"
            ><path
              fill="currentColor"
              d="m8.667 14.667 7.333-12 7.333 12zm14.666 14.667q-2.5 0-4.249-1.75-1.75-1.75-1.75-4.25-.002-2.501 1.75-4.25 1.751-1.748 4.25-1.75 2.496-.003 4.25 1.75 1.753 1.755 1.75 4.25-.004 2.495-1.75 4.25t-4.25 1.75M4 28.667V18h10.667v10.667zm19.333-2q1.401 0 2.367-.967.966-.966.967-2.366 0-1.401-.967-2.367-.966-.966-2.367-.967-1.4 0-2.366.967-.967.966-.967 2.367 0 1.4.967 2.366.966.967 2.366.967M6.667 26H12v-5.333H6.667zM13.4 12h5.2L16 7.8z"
            ></path></svg
          > View Category</label
        >
      </nav>

      <div class="tab__panels">
        <div class="tab__panel tab__panel--1">
          <Card
            title={"Feedback Makes Interaction Feel Real"}
            excerpt={"Why interface need to respond instantly to user actions, even in small ways. We all expect a physical product to react when we touch, move, or change it."}
            readTime={"20"}
            category={"fundamentals"}
            index={1}
            href={"/articles/interaction/feedback-makes-interaction-feel-real/"}
          />

          <Card
            title={"The Ripple / Impact Shape"}
            excerpt={"An object mid-interaction. A central sphere or geometric pillar being struck or pressed, sending out perfect, expanding 3D concentric ripples (like a stone dropped in perfectly still water)."}
            readTime={"16"}
            category={"interaction"}
            index={2}
            href={"/"}
          />
          <Card
            title={"Kinetic Friction & Kinetic "}
            excerpt={"Exploring the intersection of physics and motion design. How simulating mechanical drag, surface resistance, and momentum weights can turn static UI text into a tactile, living brand asset."}
            readTime={"14"}
            category={"layout"}
            index={3}
            href={"/"}
          />
          <Card
            title={"TNeomorphic Depth in Dark Modes"}
            excerpt={"A deep dive into utilizing dual drop-shadows and subtle inner glows to forge realistic, indented tactile surfaces without muddying contrast thresholds on high-end OLED displays."}
            readTime={"12"}
            category={"ui design"}
            index={4}
            href={"/"}
          />
          <Card
            title={"Micro-Gestures and Spatial Audio"}
            excerpt={"Designing for the subconscious. By pairing sub-100ms haptic triggers with localized 3D audio pings, we can create UI boundaries that users feel and hear before they even process them visually."}
            readTime={"11"}
            category={"psychology"}
            index={5}
            href={"/"}
          />
        </div>
        <div class="tab__panel tab__panel--2">
          <p>Categories goes here.</p>
        </div>
      </div>
    </div>
  </section>
</main>
