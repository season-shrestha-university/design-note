---
interface Props {
  id: string;
  title?: string;
  class?: string;
}

const { id, title, class: className } = Astro.props;
const titleId = `${id}-title`;
---

<dialog
  id={id}
  class:list={["modal", className]}
  aria-labelledby={title ? titleId : undefined}
>
  <div class="modal__panel">
    <form method="dialog" class="modal__form">
      <header class="modal__header">
        {
          Astro.slots.has("title") ? (
            <div class="modal__title" id={titleId}>
              <slot name="title" />
            </div>
          ) : title ? (
            <h2 class="modal__title" id={titleId}>
              {title}
            </h2>
          ) : null
        }
        <button type="button" class="modal__close" aria-label="Close dialog">
          ×
        </button>
      </header>
      <div class="modal__body">
        <slot />
      </div>
    </form>
  </div>
</dialog>
