---
import { CATEGORY_ICONS, formatCategoryLabel } from "@/utils";

interface Props {
  title: string;
  excerpt: string;
  readTime: string;
  category: string;
  index: number;
  href: string;
}

const { title, excerpt, readTime, category, index, href } = Astro.props;

const displayIndex = String(index).padStart(2, "0");
const categoryLabel = formatCategoryLabel(category);

const iconSrc =
  CATEGORY_ICONS[category] ?? "/icons/categories/fundamental-icon.svg";
---

<a href={href} class="card" id={`card-${displayIndex}`}>
  <div class="card__header">
    <span class="card__tag">
      <span class="card__tag-icon">
        <img src={iconSrc} alt="" width="16" height="16" />
      </span>
      {categoryLabel}
    </span>
    <span class="card__index">{displayIndex}</span>
  </div>

  <div class="card__body">
    <h2 class="card__title">{title}</h2>
    <p class="card__excerpt">{excerpt}</p>
    <span class="card__badge">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="17"
        height="17"
        fill="none"
        viewBox="0 0 17 17"
        aria-hidden="true"
        ><circle
          cx="8.5"
          cy="8.5"
          r="6.25"
          stroke="currentColor"
          stroke-width="1.5"></circle><path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M8.5 5.25V8.5l2.125 1.062"></path></svg
      >{readTime} read
    </span>
  </div>
</a>
