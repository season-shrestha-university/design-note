---
interface Props {
  title: string;
  subtitle: string;
  href: string;
}

const { title, subtitle, href } = Astro.props;
---

<li class="note__further__reading__item">
  <a href={href}>
    <h3 class="note__further__reading__item__title">{title}</h3>
    <p class="note__further__reading__item__source">{subtitle}</p>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      fill="none"
      viewBox="0 0 24 24"
      aria-hidden="true"
      ><path
        stroke="#ffa329"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 6H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6m-7 1 9-9m0 5V4h-5"
      ></path></svg
    >
  </a>
</li>
