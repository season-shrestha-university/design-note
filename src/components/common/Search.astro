---
// src/components/common/Search.astro
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const searchMetadata = articles.map((article) => ({
  id: article.id,
  title: article.data.title,
  excerpt: article.data.excerpt,
  slug: `/articles/${article.id}/`,
}));
---

<astro-search
  class="search-container"
  data-metadata={JSON.stringify(searchMetadata)}
>
  <div class="search-field">
    <svg
      class="search-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    <input
      type="text"
      class="search-input"
      placeholder="Search notes..."
      aria-label="Search articles"
    />
  </div>
  <div class="search-status" aria-live="polite"></div>
  <ul class="search-results"></ul>
</astro-search>

<style>
  .search-container {
    display: block;
    width: 100%;
    margin: var(--spacing-md) 0;
  }
  .search-field {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-icon {
    position: absolute;
    left: var(--spacing-md);
    color: var(--text-color);
    opacity: 0.5;
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: var(--spacing-md) var(--spacing-md) var(--spacing-md)
      calc(var(--spacing-xl) + var(--spacing-xs));
    border: 1.5px solid var(--border-color);
    border-radius: var(--border-radius);
    background: var(--surface);
    color: inherit;
    font-family: inherit;
    font-size: var(--font-size-md);
    outline: none;
    transition: border-color 0.2s ease;
  }
  .search-input:focus {
    border-color: var(--primary-color);
  }
  .search-status {
    font-size: var(--font-size-sm);
    color: var(--primary-color);
    margin-top: var(--spacing-xs);
    font-style: italic;
    min-height: 20px;
  }
  .search-results {
    list-style: none;
    padding: 0;
    margin: var(--spacing-sm) 0 0 0;
    max-height: 300px;
    overflow-y: auto;
  }
  .search-results :global(li) {
    margin-bottom: var(--spacing-sm);
    border-radius: var(--border-radius);
    background: var(--surface);
    border: 1px solid var(--border-color);
    transition: all 0.2s ease;
  }
  .search-results :global(li:hover) {
    transform: translateX(4px);
    border-color: var(--primary-color);
  }
  .search-results :global(a) {
    display: block;
    padding: var(--spacing-md);
    text-decoration: none;
    color: inherit;
  }
  .search-results :global(h4) {
    margin: 0 0 var(--spacing-xs) 0;
    font-size: var(--font-size-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .search-results :global(p) {
    margin: 0;
    font-size: var(--font-size-sm);
    opacity: 0.8;
    line-height: 1.4;
  }
  .search-results :global(mark) {
    background: transparent;
    color: inherit;
    font-weight: inherit;
  }
  .search-results :global(.ai-badge) {
    font-size: var(--font-size-xs);
    background: #b17a28;
    color: black;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

<script>
  interface SearchMetadata {
    id: string;
    title: string;
    excerpt: string;
    slug: string;
  }

  interface PagefindResult {
    url: string;
    meta: { title: string };
    excerpt: string;
  }

  interface AiSearchResult {
    title: string;
    excerpt: string;
    slug: string;
  }

  class AstroSearch extends HTMLElement {
    private input: HTMLInputElement | null = null;
    private status: HTMLDivElement | null = null;
    private results: HTMLUListElement | null = null;
    private debounceTimer: number | undefined;
    private pagefind: any = null;
    private isPagefindUnavailable = false;
    private metadata: SearchMetadata[] = [];
    private searchGeneration = 0;
    private abortController: AbortController | null = null;
    private boundHandleInput = () => this.handleInput();

    constructor() {
      super();
    }

    async connectedCallback() {
      this.input = this.querySelector(".search-input");
      this.status = this.querySelector(".search-status");
      this.results = this.querySelector(".search-results");

      const metadataAttr = this.getAttribute("data-metadata");
      if (metadataAttr) {
        try {
          this.metadata = JSON.parse(metadataAttr);
        } catch (e) {
          console.error("Failed to parse search metadata", e);
        }
      }

      if (this.input) {
        this.input.addEventListener("input", this.boundHandleInput);
      }
    }

    disconnectedCallback() {
      clearTimeout(this.debounceTimer);
      if (this.abortController) {
        this.abortController.abort();
        this.abortController = null;
      }
      if (this.input) {
        this.input.removeEventListener("input", this.boundHandleInput);
      }
    }

    private async initPagefind() {
      if (!this.pagefind && !this.isPagefindUnavailable) {
        try {
          // @ts-ignore
          const pagefindPath = "/pagefind/pagefind.js";
          this.pagefind = await import(/* @vite-ignore */ pagefindPath);
          await this.pagefind.init();
        } catch (e) {
          console.warn(
            "Pagefind index is not available. Falling back to semantic search API.",
          );
          this.isPagefindUnavailable = true;
        }
      }
    }

    private searchLocalMetadata(query: string): PagefindResult[] {
      if (!this.metadata || this.metadata.length === 0) return [];
      const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
      if (terms.length === 0) return [];

      const matches = this.metadata.filter((article) => {
        const titleLower = (article.title || "").toLowerCase();
        const excerptLower = (article.excerpt || "").toLowerCase();
        return terms.every(
          (term) => titleLower.includes(term) || excerptLower.includes(term),
        );
      });

      return matches.slice(0, 5).map((article) => ({
        url: article.slug,
        meta: {
          title: article.title,
        },
        excerpt: article.excerpt,
      }));
    }

    private stripMarkTags(text: string): string {
      return text.replace(/<\/?mark>/gi, "");
    }

    private isSafeUrl(url: string): boolean {
      return url.startsWith("/") && !url.startsWith("//");
    }

    private handleInput() {
      clearTimeout(this.debounceTimer);
      if (this.abortController) {
        this.abortController.abort();
        this.abortController = null;
      }

      const query = this.input?.value.trim() || "";

      if (query.length < 3) {
        this.clearAll();
        return;
      }

      this.debounceTimer = window.setTimeout(() => this.runSearch(query), 300);
    }

    private async runSearch(query: string) {
      const generation = ++this.searchGeneration;
      const isStale = () => generation !== this.searchGeneration;

      this.updateStatus("Searching...");

      // 1. Try keyword search with Pagefind
      await this.initPagefind();
      if (isStale()) return;

      if (this.pagefind) {
        const search = await this.pagefind.search(query);
        if (isStale()) return;

        if (search.results.length > 0) {
          this.updateStatus(`Found ${search.results.length} matches`);
          const topResults = search.results.slice(0, 5);
          const loadedResults = await Promise.all(
            topResults.map((r: any) => r.data()),
          );
          if (isStale()) return;
          this.renderResults(loadedResults, false);
          return;
        }
      }

      // 2. Client-side keyword fallback (pagefind unavailable or no hits)
      const localResults = this.searchLocalMetadata(query);
      if (isStale()) return;
      if (localResults.length > 0) {
        this.updateStatus(`Found ${localResults.length} matches`);
        this.renderResults(localResults, false);
        return;
      }

      // 3. Fallback to Gemini AI semantic search
      this.updateStatus(
        "No exact matches. Asking AI to find recommendations...",
      );

      this.abortController = new AbortController();
      try {
        const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`, {
          signal: this.abortController.signal,
        });
        if (isStale()) return;

        const data = await res.json();

        if (!res.ok) {
          if (res.status === 429) {
            this.updateStatus("Too many searches. Please try again later.");
          } else {
            this.updateStatus("Search request failed.");
          }
          this.clearResults();
          return;
        }

        if (!Array.isArray(data) || data.length === 0) {
          this.updateStatus("No articles found matching your query.");
          this.clearResults();
          return;
        }

        this.updateStatus("AI Recommendations:");
        this.renderResults(data as AiSearchResult[], true);
      } catch (err) {
        if (err instanceof DOMException && err.name === "AbortError") return;
        if (isStale()) return;
        this.updateStatus("Search request failed.");
        console.error(err);
      } finally {
        this.abortController = null;
      }
    }

    private updateStatus(text: string) {
      if (this.status) this.status.innerText = text;
    }

    private clearResults() {
      if (this.results) this.results.replaceChildren();
    }

    private clearAll() {
      this.clearResults();
      if (this.status) this.status.innerText = "";
    }

    private renderResults(
      articles: PagefindResult[] | AiSearchResult[],
      isAI: boolean,
    ) {
      if (!this.results) return;

      this.results.replaceChildren();

      for (const article of articles) {
        const rawTitle = isAI
          ? (article as AiSearchResult).title
          : (article as PagefindResult).meta?.title;
        const title = rawTitle ? this.stripMarkTags(String(rawTitle)) : "";
        const rawUrl = isAI
          ? (article as AiSearchResult).slug
          : (article as PagefindResult).url;
        const url = String(rawUrl || "");

        if (!this.isSafeUrl(url)) continue;

        const excerpt = article.excerpt
          ? this.stripMarkTags(String(article.excerpt))
          : "";

        const li = document.createElement("li");
        const a = document.createElement("a");
        a.href = url;

        const h4 = document.createElement("h4");
        const titleSpan = document.createElement("span");
        titleSpan.textContent = title;
        h4.appendChild(titleSpan);

        if (isAI) {
          const badge = document.createElement("span");
          badge.className = "ai-badge";
          badge.textContent = "AI";
          h4.appendChild(badge);
        }

        const p = document.createElement("p");
        p.textContent = excerpt;

        a.appendChild(h4);
        a.appendChild(p);
        li.appendChild(a);
        this.results.appendChild(li);
      }
    }
  }

  if (!customElements.get("astro-search")) {
    customElements.define("astro-search", AstroSearch);
  }
</script>
