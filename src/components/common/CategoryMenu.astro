---
import Card from "../ui/Card.astro";
---

<nav>
  <ul class="category__menu">
    <li>
      <a href="#/">
        <div class="card category__menu__item">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="100"
            height="100"
            fill="none"
            viewBox="0 0 120 120"
            ><path fill="#44694f" d="M0 0h120v120H0z"></path><path
              fill="#ffa329"
              d="M28 28h60v60H28z"></path></svg
          >
          <div class="category__menu__item__content">
            <h3>User Research</h3>
            <span class="card__badge"> 20+ Notes </span>
          </div>
        </div>
      </a>
    </li>
    <li>
      <a href="#/">
        <div class="card category__menu__item">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="120"
            height="120"
            fill="none"
            viewBox="0 0 120 120"
            ><circle cx="60" cy="60" r="60" fill="#44694f"></circle><circle
              cx="60.3"
              cy="60.3"
              r="35.8"
              fill="#ffa329"></circle></svg
          >
          <div class="category__menu__item__content">
            <h3>User Experience</h3>
            <span class="card__badge"> 20+ Notes </span>
          </div>
        </div>
      </a>
    </li>
  </ul>
</nav>

<style>
  .category__menu__item {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    min-width: 600px;
  }
  .category__menu__item__content h3 {
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-xl);
  }
</style>
