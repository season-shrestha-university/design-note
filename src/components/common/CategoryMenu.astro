---
import {
  ARTICLE_CATEGORIES,
  formatCategoryLabel,
} from "@/utils";
---

<nav>
  <ul class="category__menu">
    {
      ARTICLE_CATEGORIES.map(({ slug, icon }, index) => (
        <li>
          <a href={`/categories/${slug}/`}>
            <div class="card category__menu__item">
              <img
                class="category__menu__item__icon"
                src={icon}
                alt=""
                width="120"
                height="120"
              />
              <div class="category__menu__item__content">
                <h3>{formatCategoryLabel(slug)}</h3>
                <span class="card__badge"> 20+ Notes </span>
              </div>
              <div class="category__menu__item__index">
                {String(index + 1).padStart(2, "0")}
              </div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .category__menu__item {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    min-width: 600px;
    position: relative;
  }
  .category__menu__item__icon {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
  }
  .category__menu__item__content h3 {
    margin-bottom: var(--spacing-md);
    font-size: var(--font-size-xl);
  }
  .category__menu__item__index {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--primary-color);
    opacity: 0.3;
    font-family: "IBM Plex Mono", monospace;
    position: absolute;
    bottom: 12%;
    right: 4%;
  }
</style>
